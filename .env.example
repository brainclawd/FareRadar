POSTGRES_DB=fareradar
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/fareradar
REDIS_URL=redis://redis:6379/0

FLIGHT_PROVIDER=mock

AMADEUS_BASE_URL=https://test.api.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

KIWI_BASE_URL=https://tequila-api.kiwi.com
KIWI_API_KEY=

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false
NOTIFICATIONS_FROM_EMAIL=deals@fareradar.local


# Provider hardening
PROVIDER_MAX_RETRIES=2
PROVIDER_BACKOFF_SECONDS=0.5
PROVIDER_FAILURE_COOLDOWN_MINUTES=15
PROVIDER_FALLBACK_ORDER='["amadeus","kiwi","mock"]'

# Feed quality
DEALS_BUSINESS_CLASS_BONUS=8
DEALS_FRESHNESS_HALF_LIFE_HOURS=12


# App runtime
APP_ENV=development
CORS_ALLOWED_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'
JWT_SECRET=change-me-in-production

# Frontend deploy
NEXT_PUBLIC_API_URL=http://localhost:8000
